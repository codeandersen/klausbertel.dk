---
import Layout from '../../components/Layout.astro';
import { getHref } from '../../utils/getHref';
---

<Layout title="Referencer - Psykolog Klaus Bertel">
  <section class="py-16 bg-gradient-to-br from-primary-50 to-forest-50">
    <div class="container-custom">
      <h1 class="text-4xl md:text-5xl font-bold text-forest-900 mb-4">Referencer</h1>
      <p class="text-xl text-gray-700">Hvad klienter og virksomheder siger</p>
    </div>
  </section>
  
  <section class="py-16">
    <div class="container-custom max-w-4xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <a href={getHref('/referencer/det-siger')} class="group">
          <div class="bg-white rounded-lg shadow-md p-8 h-full hover:shadow-xl transition-shadow duration-300">
            <div class="w-16 h-16 bg-primary-100 rounded-full flex items-center justify-center mb-6 group-hover:bg-primary-200 transition-colors">
              <svg class="w-8 h-8 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"></path>
              </svg>
            </div>
            <h2 class="text-2xl font-bold text-forest-900 mb-4">Det siger klienterne</h2>
            <p class="text-gray-700 mb-4">
              Læs hvad tidligere og nuværende klienter siger om deres oplevelser med behandlingen.
            </p>
            <span class="text-primary-700 font-medium group-hover:underline">
              Læs anbefalinger →
            </span>
          </div>
        </a>
        
        <a href={getHref('/referencer/virksomhedsreferencer')} class="group">
          <div class="bg-white rounded-lg shadow-md p-8 h-full hover:shadow-xl transition-shadow duration-300">
            <div class="w-16 h-16 bg-forest-100 rounded-full flex items-center justify-center mb-6 group-hover:bg-forest-200 transition-colors">
              <svg class="w-8 h-8 text-forest-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
              </svg>
            </div>
            <h2 class="text-2xl font-bold text-forest-900 mb-4">Virksomhedsreferencer</h2>
            <p class="text-gray-700 mb-4">
              Se referencer fra virksomheder og organisationer jeg har samarbejdet med.
            </p>
            <span class="text-forest-700 font-medium group-hover:underline">
              Se referencer →
            </span>
          </div>
        </a>
      </div>
    </div>
  </section>
</Layout>
