---
import Layout from '../components/Layout.astro';
---

<Layout title="Kurser - Psykolog Klaus Bertel">
  <section class="py-16 bg-gradient-to-br from-primary-50 to-forest-50">
    <div class="container-custom">
      <h1 class="text-4xl md:text-5xl font-bold text-forest-900 mb-4">Kurser og Undervisning</h1>
      <p class="text-xl text-gray-700">Faglig udvikling og kompetenceudvikling</p>
    </div>
  </section>
  
  <section class="py-16">
    <div class="container-custom max-w-4xl">
      <div class="prose prose-lg max-w-none">
        <div class="bg-white rounded-lg shadow-md p-8 mb-8">
          <h2 class="text-2xl font-bold text-forest-900 mb-4">Supervision</h2>
          <p class="text-gray-700 mb-4">
            Jeg tilbyder supervision til psykologer, psykoterapeuter og andre faggrupper, der arbejder med 
            psykologisk behandling og rådgivning.
          </p>
          <p class="text-gray-700 mb-4">
            Supervisionen kan være individuel eller i gruppe og tager udgangspunkt i konkrete cases og 
            faglige udfordringer fra din praksis.
          </p>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-forest-700 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Individuel supervision</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-forest-700 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Gruppesupervision</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-forest-700 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Case-baseret læring</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-forest-700 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Faglig sparring og udvikling</span>
            </li>
          </ul>
        </div>
        
        <div class="bg-white rounded-lg shadow-md p-8 mb-8">
          <h2 class="text-2xl font-bold text-forest-900 mb-4">Undervisning</h2>
          <p class="text-gray-700 mb-4">
            Jeg underviser og holder foredrag om psykologiske emner for både fagfolk og lægmand.
          </p>
          <p class="text-gray-700 mb-4">
            Undervisningen kan tilpasses jeres specifikke behov og kan omfatte emner som:
          </p>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-forest-700 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Stress og stresshåndtering</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-forest-700 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Krisepsykologi og krisehåndtering</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-forest-700 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Angst og depression</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-forest-700 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Kommunikation og relationer</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-forest-700 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Trivsel og mental sundhed</span>
            </li>
          </ul>
        </div>
        
        <div class="bg-forest-50 rounded-lg p-8">
          <h2 class="text-2xl font-bold text-forest-900 mb-4">Kontakt for booking</h2>
          <p class="text-gray-700 mb-4">
            Er du interesseret i supervision eller undervisning? Kontakt mig for en uforpligtende samtale 
            om dine behov og ønsker.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="sms:+4520521981" class="btn-primary">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path>
              </svg>
              Send SMS
            </a>
            <a href="mailto:klaus@arospsyk.dk" class="btn-secondary">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
              Send email
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
