---

<Layout title="Anbefalinger og kursusbeviser - Psykolog Klaus Bertel">
  <section class="py-16 bg-gradient-to-br from-primary-50 to-forest-50">
    <div class="container-custom">
      <h1 class="text-4xl md:text-5xl font-bold text-forest-900 mb-4">Anbefalinger og kursusbeviser</h1>
      <p class="text-xl text-gray-700">Dokumentation for autorisationer, efteruddannelse og specialisering</p>
    </div>
  </section>
  
  <section class="py-16">
    <div class="container-custom max-w-5xl">
      <div class="bg-white rounded-lg shadow-md p-8 mb-8">
        <h2 class="text-2xl font-bold text-forest-900 mb-6">Autorisationer</h2>
        <ul class="space-y-3">
          {certificates.autorisationer.map(cert => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-forest-700 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              {cert.url ? (
                <a href={getUrl(cert.url)} target="_blank" rel="noopener noreferrer" class="text-primary-700 hover:underline">
                  {cert.title}
                </a>
              ) : (
                <span class="text-gray-700">{cert.title}</span>
              )}
            </li>
          ))}
        </ul>
      </div>

      <div class="bg-white rounded-lg shadow-md p-8 mb-8">
        <h2 class="text-2xl font-bold text-forest-900 mb-6">Supervision</h2>
        <ul class="space-y-3">
          {certificates.supervision.map(cert => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary-700 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
              </svg>
              {cert.url ? (
                <a href={getUrl(cert.url)} target="_blank" rel="noopener noreferrer" class="text-primary-700 hover:underline">
                  {cert.title}
                </a>
              ) : (
                <span class="text-gray-700">{cert.title}</span>
              )}
            </li>
          ))}
        </ul>
      </div>

      <div class="bg-white rounded-lg shadow-md p-8 mb-8">
        <h2 class="text-2xl font-bold text-forest-900 mb-6">Dansk Psykolog Forening – Kurser</h2>
        <ul class="space-y-3">
          {certificates.danskPsykologForening.map(cert => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-forest-700 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <a href={getUrl(cert.url)} target="_blank" rel="noopener noreferrer" class="text-primary-700 hover:underline">
                {cert.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="bg-white rounded-lg shadow-md p-8 mb-8">
        <h2 class="text-2xl font-bold text-forest-900 mb-6">Diplomer</h2>
        <ul class="space-y-3">
          {certificates.diplomer.map(cert => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary-700 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path>
              </svg>
              <a href={getUrl(cert.url)} target="_blank" rel="noopener noreferrer" class="text-primary-700 hover:underline">
                {cert.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="bg-white rounded-lg shadow-md p-8 mb-8">
        <h2 class="text-2xl font-bold text-forest-900 mb-6">Kursusbeviser</h2>
        <p class="text-gray-700 mb-6">
          Omfattende efteruddannelse inden for psykoterapi, traumebehandling, stresshåndtering og specialiserede behandlingsmetoder.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          {certificates.kursusbeviser.map(cert => (
            <div class="flex items-start gap-2">
              <svg class="w-4 h-4 text-forest-700 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <a href={cert.url} target="_blank" rel="noopener noreferrer" class="text-sm text-primary-700 hover:underline">
                {cert.title}
              </a>
            </div>
          ))}
        </div>
      </div>

      <div class="bg-forest-50 rounded-lg p-8">
        <h2 class="text-2xl font-bold text-forest-900 mb-6">Konsulent Tilknytninger</h2>
        <ul class="space-y-3">
          {certificates.konsulent.map(cert => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-forest-700 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
              <span class="text-gray-700">{cert.title}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</Layout>
