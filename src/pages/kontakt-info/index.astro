---
import Layout from '../../components/Layout.astro';
import { getHref } from '../../utils/getHref';

const basePath = import.meta.env.BASE_URL || '/';
const locationImageUrl = basePath === '/' ? '/images/location.jpg' : basePath.replace(/\/$/, '') + '/images/location.jpg';
---

<Layout title="Kontakt info - Psykolog Klaus Bertel">
  <section class="py-16 bg-gradient-to-br from-primary-50 to-forest-50">
    <div class="container-custom">
      <h1 class="text-4xl md:text-5xl font-bold text-forest-900 mb-4">Kontakt information</h1>
      <p class="text-xl text-gray-700">Sådan kommer du i kontakt med klinikken</p>
    </div>
  </section>
  
  <section class="py-16">
    <div class="container-custom max-w-4xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
        <div class="bg-white rounded-lg shadow-md p-8">
          <h2 class="text-2xl font-bold text-forest-900 mb-6">Kontakt</h2>
          <div class="space-y-4">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-primary-100 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-forest-900 mb-1">Email</h3>
                <a href="mailto:klaus@arospsyk.dk" class="text-primary-700 hover:underline">
                  klaus@arospsyk.dk
                </a>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-primary-100 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-forest-900 mb-1">SMS</h3>
                <a href="sms:+4520521981" class="text-primary-700 hover:underline text-lg">
                  +45 20 52 19 81
                </a>
                <p class="text-sm text-gray-600 mt-1">Foretrukken kontaktmetode</p>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-primary-100 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-forest-900 mb-1">Adresse</h3>
                <p class="text-gray-700">
                  Telefontorvet 1, 2. SAL<br>
                  8000 Århus C
                </p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="bg-white rounded-lg shadow-md p-8">
          <h2 class="text-2xl font-bold text-forest-900 mb-6">Åbningstider</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center py-2 border-b border-gray-200">
              <span class="font-medium text-gray-700">Mandag - Fredag</span>
              <span class="text-gray-600">08:00 - 17:00</span>
            </div>
            <div class="flex justify-between items-center py-2 border-b border-gray-200">
              <span class="font-medium text-gray-700">Lørdag - Søndag</span>
              <span class="text-gray-600">Lukket</span>
            </div>
          </div>
          
          <div class="mt-6 p-4 bg-primary-50 rounded-lg">
            <p class="text-sm text-gray-700">
              <strong>Bemærk:</strong> Tider aftales individuelt. Kontakt mig for at aftale en tid, 
              der passer til dit skema.
            </p>
          </div>
        </div>
      </div>
      
      <div class="bg-white rounded-lg shadow-md p-8 mb-8">
        <h2 class="text-2xl font-bold text-forest-900 mb-4">Beliggenhed</h2>
        <p class="text-gray-700 mb-4">
          Klinikken ligger centralt i Aarhus på Telefontorvet – mellem Magasin og Salling og over for Busgaden.
        </p>
        
        <div class="mb-6">
          <img 
            src={locationImageUrl}
            alt="Telefontorvet 1, 2. sal - Indgang til klinikken" 
            class="w-full rounded-lg shadow-md"
          />
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <h3 class="font-semibold text-forest-900 mb-3">Transport</h3>
            <ul class="space-y-2 text-gray-700">
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-forest-700 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Ca. 650 meter fra banegården</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-forest-700 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Tæt på busgaden</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-forest-700 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>God adgang til offentlig transport</span>
              </li>
            </ul>
          </div>
          
          <div>
            <h3 class="font-semibold text-forest-900 mb-3">Parkering</h3>
            <ul class="space-y-2 text-gray-700">
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-forest-700 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Parkering i Magasin</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-forest-700 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Parkering i Salling</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-forest-700 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Offentlige parkeringspladser i nærheden</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <a href={getHref('/kontakt-info/afbudsregler')} class="group">
          <div class="bg-white rounded-lg shadow-md p-6 h-full hover:shadow-xl transition-shadow duration-300">
            <div class="flex items-start gap-4">
              <svg class="w-8 h-8 text-forest-700 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <h3 class="text-lg font-semibold text-forest-900 mb-2 group-hover:text-forest-700">Afbudsregler</h3>
                <p class="text-gray-600 text-sm">Læs om regler ved afbud og aflysning af aftaler</p>
              </div>
            </div>
          </div>
        </a>
        
        <a href={getHref('/kontakt-info/privatlivspolitik')} class="group">
          <div class="bg-white rounded-lg shadow-md p-6 h-full hover:shadow-xl transition-shadow duration-300">
            <div class="flex items-start gap-4">
              <svg class="w-8 h-8 text-forest-700 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
              </svg>
              <div>
                <h3 class="text-lg font-semibold text-forest-900 mb-2 group-hover:text-forest-700">Privatlivspolitik</h3>
                <p class="text-gray-600 text-sm">Information om behandling af persondata</p>
              </div>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>
</Layout>
