---
import Layout from '../components/Layout.astro';
---

<Layout title="CV - Psykolog Klaus Bertel">
  <section class="py-16 bg-gradient-to-br from-primary-50 to-forest-50">
    <div class="container-custom">
      <h1 class="text-4xl md:text-5xl font-bold text-forest-900 mb-4">Curriculum Vitae</h1>
      <p class="text-xl text-gray-700">Klaus Bertel - Autoriseret Psykolog</p>
    </div>
  </section>
  
  <section class="py-16">
    <div class="container-custom max-w-4xl">
      <div class="prose prose-lg max-w-none">
        <div class="bg-white rounded-lg shadow-md p-8 mb-8">
          <h2 class="text-2xl font-bold text-forest-900 mb-4">Uddannelse</h2>
          <ul class="space-y-4">
            <li class="border-l-4 border-forest-700 pl-4">
              <strong class="text-forest-900">Cand.psych.</strong> - Psykologi<br>
              <span class="text-gray-600">Aarhus Universitet</span>
            </li>
            <li class="border-l-4 border-forest-700 pl-4">
              <strong class="text-forest-900">Specialist i Psykoterapi</strong><br>
              <span class="text-gray-600">Autoriseret af Dansk Psykolog Forening</span>
            </li>
            <li class="border-l-4 border-forest-700 pl-4">
              <strong class="text-forest-900">Krisepsykolog</strong><br>
              <span class="text-gray-600">Specialuddannelse i krisepsykologi</span>
            </li>
          </ul>
        </div>
        
        <div class="bg-white rounded-lg shadow-md p-8 mb-8">
          <h2 class="text-2xl font-bold text-forest-900 mb-4">Erfaring</h2>
          <p class="text-gray-700 mb-4">
            Jeg har bred klinisk erfaring inden for psykologisk behandling og rådgivning. 
            Min erfaring omfatter arbejde med:
          </p>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-forest-700 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Behandling af angst, depression, stress og kriser</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-forest-700 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Henvisninger fra læger og tilknytning til sygesikringen</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-forest-700 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Livskriser og akut krisehjælp</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-forest-700 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Tilknytning til Falck Healthcare</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-forest-700 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Konsulent i Belastningspsykologisk Institut</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-forest-700 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Tilknyttet FAS – Foreningen af Speciallæger</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-forest-700 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Samarbejde med LGBT+ Gruppen</span>
            </li>
          </ul>
        </div>
        
        <div class="bg-white rounded-lg shadow-md p-8 mb-8">
          <h2 class="text-2xl font-bold text-forest-900 mb-4">Tilgang</h2>
          <p class="text-gray-700 mb-4">
            Jeg arbejder i en åben dialog med mine klienter, da det er vigtigt for mig, at de føler sig trygge 
            og bliver en aktiv medspiller i forløbet – og ALTID ved, hvor de har mig.
          </p>
          <p class="text-gray-700">
            Min tilgang er helhedsorienteret og tager udgangspunkt i den enkelte persons behov og situation. 
            Jeg kombinerer forskellige terapeutiske metoder for at sikre den bedst mulige behandling.
          </p>
        </div>
        
        <div class="bg-forest-50 rounded-lg p-8">
          <h2 class="text-2xl font-bold text-forest-900 mb-4">Medlemskaber</h2>
          <ul class="space-y-2 text-gray-700">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-forest-700 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span>Dansk Psykolog Forening</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-forest-700 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span>Foreningen af Speciallæger (FAS)</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-forest-700 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span>Belastningspsykologisk Institut</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</Layout>
