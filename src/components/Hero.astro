---
---

<section class="relative min-h-[700px] flex items-center justify-start bg-gray-900 overflow-hidden">
  <!-- Background Image with Animation -->
  <div class="absolute inset-0 bg-cover bg-center hero-bg-animate" style="background-image: url('/images/background.png'); background-position: center center;">
    <div class="absolute inset-0 bg-gradient-to-r from-black/40 to-black/20"></div>
  </div>
  
  <!-- Content -->
  <div class="container-custom relative z-10 py-24">
    <div class="max-w-2xl">
      <p class="text-white/90 text-sm uppercase tracking-wider mb-4 font-medium">Velkommen til klinikken</p>
      <h1 class="text-5xl md:text-6xl font-bold text-white mb-6 leading-tight">
        Et trygt rum for<br>forandring og trivsel
      </h1>
      <p class="text-lg text-white/90 mb-8 leading-relaxed">
        Jeg tilbyder professionel psykologisk rådgivning og behandling af unge og voksne med stress, angst, depression, kriser og livsudfordringer.
      </p>
    </div>
  </div>
</section>

<style>
  @keyframes heroZoom {
    0% {
      transform: scale(1);
    }
    100% {
      transform: scale(1.1);
    }
  }
  
  .hero-bg-animate {
    animation: heroZoom 20s ease-in-out infinite alternate;
  }
</style>
